{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake_config",
            "type": "shell",
            "command": "cmake -E rm -rf build && cmake -B build -DCMAKE_TOOLCHAIN_FILE=toolchain.cmake",
            "problemMatcher": []
        },
        {
            "label": "build",
            "type": "shell",
            "command": "cmake --build build -j4",
            "dependsOn": [
                "cmake_config"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
        }
    ]
}